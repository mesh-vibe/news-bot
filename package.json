{
  "name": "meshvibe-news-bot",
  "version": "1.0.0",
  "description": "Personal news aggregation CLI that learns from browser history",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "newsbot": "dist/cli/index.js"
  },
  "scripts": {
    "build": "node_modules/.bin/tsc -p tsconfig.build.json",
    "dev": "node_modules/.bin/tsc -p tsconfig.build.json --watch",
    "lint": "tsc --noEmit",
    "test": "node_modules/.bin/vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "better-sqlite3": "^11.7.0",
    "commander": "^12.1.0",
    "open": "^10.1.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.4",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
